// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored. These are the publishable values only —
// the Supabase URL and the publishable/anon key (which ship in every client
// by design). NEVER put the service-role key here.
//
// Note: xcconfig treats // as a comment, so the URL's https:// must be escaped
// by splitting the slashes — use the form below exactly.

SUPABASE_URL = https:/$()/zqhmurpwgwsnmtkzgyeu.supabase.co
SUPABASE_ANON_KEY = sb_publishable_xxxxxxxxxxxxxxxx
